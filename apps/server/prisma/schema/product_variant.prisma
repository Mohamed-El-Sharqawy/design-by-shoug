model AbayaLength {
  id String @id @default(cuid())

  inches        Int
  labelEn       String
  labelAr       String
  idealHeightCm Decimal @db.Decimal(5, 2)
  idealHeightFt String

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]

  @@unique([inches])
  @@map("abaya_lengths")
}

model Color {
  id String @id @default(cuid())

  code    String  @unique
  nameEn  String
  nameAr  String
  hexCode String?

  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants ProductVariant[]

  @@map("colors")
}

model ProductVariant {
  id  String @id @default(cuid())
  sku String @unique

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  abayaLengthId String?
  abayaLength   AbayaLength? @relation(fields: [abayaLengthId], references: [id])

  colorId String?
  color   Color?  @relation(fields: [colorId], references: [id])

  priceAdjustment Decimal @default(0) @db.Decimal(10, 2)
  stock           Int     @default(0)
  lowStockAlert   Int     @default(5)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, abayaLengthId, colorId])
  @@index([productId])
  @@index([stock])
  @@map("product_variants")
}
