model SiteSettings {
  id                String   @id @default(cuid())
  key               String   @unique
  value             String
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("site_settings")
}

model ShippingZone {
  id                String   @id @default(cuid())
  
  nameEn            String
  nameAr            String
  
  countries         String[]
  cities            String[]
  
  baseCost          Decimal  @db.Decimal(10, 2)
  freeShippingMin   Decimal? @db.Decimal(10, 2)
  
  estimatedDaysMin  Int      @default(1)
  estimatedDaysMax  Int      @default(5)
  
  isActive          Boolean  @default(true)
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("shipping_zones")
}
