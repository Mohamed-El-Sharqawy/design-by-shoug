model Address {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  label         String?
  fullName      String
  phone         String
  
  country       String
  city          String
  district      String?
  street        String
  building      String?
  apartment     String?
  postalCode    String?
  
  isDefault     Boolean  @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]

  @@map("addresses")
}
