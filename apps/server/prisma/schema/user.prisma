model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  passwordHash  String
  role          UserRole  @default(CUSTOMER)
  
  firstName     String?
  lastName      String?
  avatarUrl     String?
  
  isActive      Boolean   @default(true)
  
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses     Address[]
  orders        Order[]
  cart          Cart?
  reviews       Review[]
  wishlist      WishlistItem[]

  @@map("users")
}
