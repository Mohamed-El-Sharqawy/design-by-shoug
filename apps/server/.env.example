# Database connection string
# Replace with your actual PostgreSQL credentials
DATABASE_URL="postgresql://user:password@localhost:5432/designbyshoug?schema=public"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:3000,http://localhost:3002,https://designbyshoug.com,https://www.designbyshoug.com"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Cloudflare R2
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET="designbyshoug"
R2_PUBLIC_URL="https://cdn.designbyshoug.com"

# Ziina
ZIINA_SECRET_KEY="your-ziina-secret-key"
ZIINA_WEBHOOK_SECRET="your-ziina-webhook-secret"

# Mailtrap
MAIL_HOST="sandbox.smtp.mailtrap.io"
MAIL_PORT=587
MAIL_USER="your-mailtrap-user"
MAIL_PASS="your-mailtrap-password"
MAIL_FROM="DesignByShoug <noreply@designbyshoug.com>"
MAILTRAP_TOKEN="your-mailtrap-token"
MAILTRAP_SENDER_EMAIL="hello@designbyshoug.com"
MAILTRAP_SENDER_NAME="Design By Shoug"
OWNER_EMAILS="owner1@example.com,owner2@example.com"

# Frontend URL (for password reset links)
FRONTEND_URL="http://localhost:3000"

# Meta Conversions API
META_PIXEL_ID="your-meta-pixel-id"
META_ACCESS_TOKEN="your-meta-access-token"
# Only set in development — removes test events from production reporting
# META_TEST_EVENT_CODE="TESTXXXXXX"
